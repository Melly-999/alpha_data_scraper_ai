# MellyTrade API — example environment
# Copy to `.env` and fill with real values. NEVER commit `.env`.

# --- Persistence ---
# SQLite by default; swap in Postgres for production:
#   postgresql+psycopg://user:pass@host:5432/mellytrade
DATABASE_URL=sqlite:///./mellytrade.db

# --- Auth / transport ---
FASTAPI_KEY=change-me-api-key
CF_HUB_URL=http://127.0.0.1:8787/api/publish
CF_API_SECRET=change-me-hub-secret

# --- Risk rules (hard defaults; never loosen without explicit approval) ---
COOLDOWN_SECONDS=60
MIN_CONFIDENCE=70
MAX_RISK_PERCENT=1.0

# --- Alpha / LSTM bridge ---
# Absolute path to the alpha_data_scraper_ai repo root (so the MT5 bridge
# can import its LSTM pipeline). Example Windows workspace:
#   ALPHA_REPO_PATH=C:\AI\MellyTrade_Workspace\02_Repo\alpha_data_scraper_ai
ALPHA_REPO_PATH=/absolute/path/to/alpha_data_scraper_ai
ALPHA_LSTM_CLASS=lstm_model.LSTMPipeline
# Optional override for a callable instead of a class:
# ALPHA_LSTM_FUNCTION=lstm_model.predict_next_delta
# Optional path to a pre-trained model checkpoint (skips fit on cold start):
# ALPHA_LSTM_CHECKPOINT=/abs/path/to/lstm.keras

# --- MT5 bridge (consumed by mellytrade_v3/mt5/mt5_bridge.py) ---
MELLYTRADE_API_URL=http://127.0.0.1:8000
MT5_SYMBOL=EURUSD
MT5_TIMEFRAME=M5
MT5_BARS=300
MT5_SL_PIPS=20
MT5_TP_PIPS=40
MT5_RISK_PERCENT=0.5

# --- CloudMCP (shared between .mcp.json and .cursor/mcp.json) ---
# Set a single token that all CloudMCP entries reference as ${CLOUDMCP_TOKEN}.
CLOUDMCP_TOKEN=change-me-cloudmcp-token
