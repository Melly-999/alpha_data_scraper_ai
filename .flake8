[flake8]
max-line-length = 88
exclude =
    .git,
    .venv,
    __pycache__
extend-ignore =
    E203,
    W503
per-file-ignores =
    # dashboard.py contains HTML template strings that exceed 88 chars
    dashboard.py: E501
    # main.py uses sys.path bootstrap before project imports
    main.py: E402
