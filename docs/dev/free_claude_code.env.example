# Free Claude Code — local proxy environment template.
# Copy to a private file (e.g. `free_claude_code.env`) and fill in real values.
# DO NOT commit a filled-in copy. `.env*` is git-ignored.

# Placeholder token. The local proxy ignores it but Claude Code requires
# *some* value to be set. Keep it dummy — never put a real Anthropic key here.
ANTHROPIC_AUTH_TOKEN=freecc

# Local proxy URL. Must match the host/port used by
# scripts/start_free_claude_code_proxy.ps1.
ANTHROPIC_BASE_URL=http://127.0.0.1:8082

# Lets Claude Code discover model ids from the gateway.
CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

# OpenRouter API key. Only needed if you route through OpenRouter.
# Replace before use; never commit a real key.
OPENROUTER_API_KEY=replace_me

# Model id routed by the proxy. Examples:
#   open_router/deepseek/deepseek-r1-0528:free
#   open_router/qwen/qwen-2.5-coder-32b-instruct:free
#   ollama/qwen2.5-coder:7b
MODEL=open_router/deepseek/deepseek-r1-0528:free

# Keep raw payload / SSE logging OFF. Prevents prompts and keys from
# being persisted to disk.
LOG_RAW_API_PAYLOADS=false
LOG_RAW_SSE_EVENTS=false

# Restrict Claude Code edits to the MellyTrade workspace.
ALLOWED_DIR=C:/AI/MellyTrade_Workspace/02_Repo

# Sandbox workspace for transient files (relative to repo root).
CLAUDE_WORKSPACE=./agent_workspace
