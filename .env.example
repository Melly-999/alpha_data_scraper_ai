# Copy to .env and fill from Neon Console or `neonctl connection-string`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL_VERCEL_DEV=postgresql://USER:PASSWORD@VERCEL_DEV_HOST/neondb?sslmode=require

NEON_ORG_ID=org-placeholder
NEON_PROJECT_ID=project-placeholder
NEON_BRANCH_LOCAL=local-branch
NEON_BRANCH_VERCEL=vercel-branch
ACE_NAMESPACE=workspace-placeholder
