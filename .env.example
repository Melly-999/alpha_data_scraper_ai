CLAUDE_API_KEY=
NEWSAPI_KEY=
MELLYTRADE_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=http://127.0.0.1:8001/api

# ---------------------------------------------------------------------------
# Broker selection
# ---------------------------------------------------------------------------
# Active broker adapter for the safe paper-broker factory. Existing MT5
# pipeline keeps running independently regardless of this value.
BROKER_ADAPTER=mt5_demo

# ---------------------------------------------------------------------------
# IBKR Paper Adapter (v1, safety-first)
# ---------------------------------------------------------------------------
# All values below are non-secret defaults for Interactive Brokers paper
# trading. Never put usernames, passwords, account numbers or tokens in this
# file - log into TWS / IB Gateway manually with PaperTrader credentials.
IBKR_ENABLED=false
IBKR_MODE=paper
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_READ_ONLY=true

# IBKR execution safety (live order placement is blocked at the adapter
# level regardless of these values - see docs/IBKR_PAPER_ADAPTER.md).
IBKR_ALLOW_PAPER_ORDERS=false
IBKR_ALLOW_LIVE_ORDERS=false
IBKR_MAX_ORDER_VALUE=100
IBKR_MAX_POSITION_VALUE=100
