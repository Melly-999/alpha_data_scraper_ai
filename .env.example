# .env.example
# Kopiuj do .env i wpisz swoje wartości
# NIGDY nie commituj .env do Gita!

# === CLAUDE API ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# === ALPACA (jeśli będziesz używać) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# === TELEGRAM NOTIFICATIONS ===
